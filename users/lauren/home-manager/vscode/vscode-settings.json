  "ansible.lightspeed.enabled": false,

  "sqlite.sqlite3": "/usr/bin/sqlite3",

  "angular.experimental-ivy": true,

  "partialDiff.enableTelemetry": false,
  "gitlens.telemetry.enabled": false,
  "redhat.telemetry.enabled": false,

  "license.author": "Lauren Cunningham",
  "license.year": "auto",

  "leetcode.workspaceFolder": "~/Github/dudeofawesome/leetcode",
  "leetcode.defaultLanguage": "typescript",
  "leetcode.hint.commandShortcut": false,
  "leetcode.hint.configWebviewMarkdown": false,

  // disable LLM junk
  "chat.commandCenter.enabled": false,
  "chat.disableAIFeatures": true,
  "chatgpt.commentCodeLensEnabled": false,
  // now M$ is hiding Copilot settings behind obscure names…
  "workbench.editor.empty.hint": "hidden",

  "claudeCode.useCtrlEnterToSend": true,
  "chatgpt.composerEnterBehavior": "cmdIfMultiline",

  "1password.editor.suggestStorage": false
}
