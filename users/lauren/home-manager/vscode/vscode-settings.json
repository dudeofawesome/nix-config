      "zepto"
    ],
    "yaml": ["yaml", "chef", "ansible", "jinja"],
    "scss": ["sass", "compass", "bourbon", "neat", "susy", "css"],
    "nix": ["nix", "nixpkgs", "nix-darwin", "nixos", "home-manager"],
    "cpp": ["arduino", "cpp", "c", "manpages"],
    "fish": ["fish"],
    "scad": ["OpenSCAD", "openscad", "scad"],
    "java": [
      "java",
      "javafx",
      "grails",
      "groovy",
      "playjava",
      "spring",
      "cvj",
      "processing",
      "spigotmc-1.12.2:"
    ],
    "dockerfile": ["docker"]
  },

  "cSpell.enabled": true,
  "cSpell.enableFiletypes": ["*"],
  "cSpell.dictionaries": [
    "en_us",
    "companies",
    "filetypes",
    "misc",
    "softwareTerms",
    "typescript",
    "node",
    "html",
    "css",
    "fonts"
  ],
  "cSpell.allowCompoundWords": true,
  "cSpell.userWords": [
