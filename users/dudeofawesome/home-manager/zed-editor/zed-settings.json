{
  "$schema": "zed://schemas/settings/user",

  "ui_font_size": 14,
  "ui_font_family": "FiraCode Nerd Font Mono",
  "buffer_font_size": 12,
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "terminal": {
    "font_size": 12,
    "font_family": "FiraCode Nerd Font Mono",
    "blinking": "on",
    "cursor_shape": "bar"
  },

  "theme": {
    "dark": "Bearded Theme Arc",
    "light": "One Light",
    "mode": "system"
  },

  "colorize_brackets": true,

  "languages": {
    "Nix": {
      "formatter": {
        "external": {
          "command": "nixfmt"
        }
      },
      "language_servers": ["nil", "!nixd"]
    }
  }
}
