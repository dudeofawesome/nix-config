{
  pkgs,
  pkgs-stable,
  pkgs-unstable,
  lib,
  config,
  ...
}:

let
  inherit (lib) mkOption types;
in
{
  options = {
    programs.vscode = {
      mutableUserSettings = mkOption {
        type = with types; nullOr path;
        default = null;
      };
    };
  };

  config =
    let
      cfg = config.programs.vscode;

      user_dir =
        if pkgs.stdenv.targetPlatform.isDarwin then
          "${config.home.homeDirectory}/Library/Application Support/Code/User"
        else if pkgs.stdenv.targetPlatform.isLinux then
          "${config.home.homeDirectory}/.config/Code/User"
        else
          abort;
      config_file_path = "${user_dir}/settings.json";
      global_settings_db_path = "${user_dir}/globalStorage/state.vscdb";
    in

    lib.mkIf cfg.enable {
      home = {
        activation = {
          createVSCodeMutableUserSettings = lib.mkIf (cfg.mutableUserSettings != null) (
            lib.hm.dag.entryAfter [ "writeBoundary" ] ''
              run mkdir -p "$(dirname "${config_file_path}")"

              # Detect OS theme setting
              os_theme="$(/usr/bin/defaults read -g AppleInterfaceStyle 2> /dev/null || echo "Light")"
              # Read preferred color theme
              theme="$(
                ${lib.getExe pkgs.gnugrep} -Po \
                  '(?<="workbench.preferred'"$os_theme"'ColorTheme": ").+(?=")' \
                  "${cfg.mutableUserSettings}" \
                  || true
              )"

              # Escape slashes for later use in sed
              function escape_for_sed {
                echo "$1" | ${lib.getExe pkgs.gnused} -Ee 's/\//\\\//gi'
              }

              mutated_settings="$(cat "${cfg.mutableUserSettings}")"

              # Modify the selected theme to prevent jerk
              if [ -n "$theme" ]; then
                mutated_settings="$(echo "$mutated_settings" | ${lib.getExe pkgs.gnused} -Ee 's/("workbench.colorTheme"): "(.+)"/\1: "'"$theme"'"/i')"
              fi

              ${lib.pipe
                [
                  (lib.optional (config.programs.claude-code.enable) ''
                    claude_path="$(escape_for_sed "${lib.getExe config.programs.claude-code.finalPackage}")"
                    mutated_settings="$(echo "$mutated_settings" | sed -Ee 's/("claudeCode.claudeProcessWrapper"): "(.+)"/\1: "'"$claude_path"'"/i')"
                  '')
                  (lib.optional (config.programs.kubectl.enable) ''
                    kubectl_path="$(escape_for_sed "${lib.getExe config.programs.kubectl.package}")"
                    mutated_settings="$(echo "$mutated_settings" \
                      | ${lib.getExe pkgs.gnused} -Ee 's/("vscode-kubernetes.kubectl-path"): "(.+)"/\1: "'"$kubectl_path"'"/i' \
                      | ${lib.getExe pkgs.gnused} -Ee 's/("vs-kubernetes.kubectl-path"): "(.+)"/\1: "'"$kubectl_path"'"/i' \
                    )"
                  '')
                ]
                [
                  lib.flatten
                  (lib.concatStringsSep "\n")
                ]
              }

              prettier_path="$(escape_for_sed "${pkgs-stable.prettier}/lib/node_modules/prettier")"
              helm_path="$(escape_for_sed "${lib.getExe pkgs-stable.kubernetes-helm}")"
              gitlab_ci_ls_path="$(escape_for_sed "${lib.getExe pkgs-stable.gitlab-ci-ls}")"
              d2_path="$(escape_for_sed "${lib.getExe pkgs-stable.d2}")"
              jdk_path="$(escape_for_sed "${pkgs-stable.jdk}")"

              mutated_settings="$(echo "$mutated_settings" \
                `# Add header about nix` \
                | ${lib.getExe pkgs.gnused} -e '1i \/\/ Generated by Home Manager' \
                \
                `# Point to nix's Prettier` \
                | ${lib.getExe pkgs.gnused} -Ee 's/("prettier.prettierPath"): "(.+)"/\1: "'"$prettier_path"'"/i' \
                `# Point to nix's helm` \
                | ${lib.getExe pkgs.gnused} -Ee 's/("vscode-kubernetes.helm-path"): "(.+)"/\1: "'"$helm_path"'"/i' \
                | sed -Ee 's/("vs-kubernetes.helm-path"): "(.+)"/\1: "'"$helm_path"'"/i' \
                `# Point to nix's gitlab-ci-ls` \
                | ${lib.getExe pkgs.gnused} -Ee 's/("gitlabLs.executablePath"): "(.+)"/\1: "'"$gitlab_ci_ls_path"'"/i' \
                `# Point to nix's d2` \
                | ${lib.getExe pkgs.gnused} -Ee 's/("D2.execPath"): "(.+)"/\1: "'"$d2_path"'"/i' \
                `# Point to nix's jdk` \
                | ${lib.getExe pkgs.gnused} -Ee 's/("java.jdt.ls.java.home"): "(.+)"/\1: "'"$jdk_path"'"/i' \
              )"

              if echo "$mutated_settings" | ${lib.getExe pkgs.gnugrep} -Fq "this should be replaced by nix"; then
                echo "VS Code settings still contain placeholder: this should be replaced by nix" >&2
                exit 1
              fi

              # Overwrite VS Code settings
              echo "$mutated_settings" \
              | run --quiet ${lib.getExe' pkgs.coreutils "tee"} "${config_file_path}"
            ''
          );
        };
      };
    };
}
