{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',

  extends: ['config:best-practices'],

  nix: {
    enabled: false,
  },

  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: ['/^flake\\.nix$/'],
      matchStrings: [
        '# renovate-flake: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) packageName=(?<packageName>\\S+)(?: versioning=(?<versioning>\\S+))?(?: currentValue=(?<currentValue>\\S+))? currentDigest=(?<currentDigest>\\S+)',
      ],
    },
  ],

  packageRules: [
    {
      matchManagers: ['custom.regex'],
      matchFileNames: ['flake.nix'],
      matchDepNames: [
        'nixpkgs-*',
        'nur',
        'op-shell-plugins',
        'claude-code-nix',
        'codex-cli-nix',
      ],
      groupName: 'nix flake core',
      groupSlug: 'nix-flake-core',
    },
    {
      matchManagers: ['custom.regex'],
      matchFileNames: ['flake.nix'],
      matchDepNames: [
        'dudeofawesome_dotfiles',
        'upaymeifixit_dotfiles',
        'vim-lumen',
        'fish-osx',
        'fish-node-binpath',
        'fish-node-version',
        'fish-shell-integrations',
        'fish-editor-updater',
        'fish-nvm',
      ],
      groupName: 'shell and dotfiles',
      groupSlug: 'shell-and-dotfiles',
    },
    {
      matchManagers: ['custom.regex'],
      matchFileNames: ['flake.nix'],
      matchDepNames: ['home-manager', 'home-manager-master'],
      groupName: 'home-manager',
      groupSlug: 'home-manager',
    },
    {
      matchManagers: ['custom.regex'],
      matchFileNames: ['flake.nix'],
      postUpgradeTasks: {
        commands: ['./scripts/renovate-update-flake-input.sh {{{depName}}}'],
        fileFilters: ['flake.nix', 'flake.lock'],
        executionMode: 'update',
      },
    },
  ],
}
